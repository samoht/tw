rules:
   - files: tmp/*
     exclude: [*]
   - files: lib/*
     exclude: [E205]
   - files: lib/css/*
     exclude: [E205]
   # Modules included in tw.ml need E330 exceptions to expose the proper API
   - files: lib/prose.ml*
     exclude: [E330]
   - files: lib/color.ml*
     exclude: [E330]
   - files: lib/columns.ml*
     exclude: [E330]
   - files: lib/containers.ml*
     exclude: [E330]
   - files: lib/cursor.ml*
     exclude: [E330]
   - files: lib/flex.ml*
     exclude: [E330]
   - files: lib/gap.ml*
     exclude: [E330]
   - files: lib/overflow.ml*
     exclude: [E330]
   - files: lib/touch.ml*
     exclude: [E330]
   - files: lib/text_shadow.ml*
     exclude: [E330]
   - files: lib/scroll.ml*
     exclude: [E330]
   - files: lib/grid.ml*
     exclude: [E330]
   - files: lib/contain.ml*
     exclude: [E330]
   - files: lib/overscroll.ml*
     exclude: [E330]
   - files: lib/divide.ml*
     exclude: [E330]
   - files: lib/field_sizing.ml*
     exclude: [E330]
   - files: lib/style.ml*
     exclude: [E330]
